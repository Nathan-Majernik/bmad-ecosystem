no_digested

parameter[lattice] = "GPU tracking bend with exact_multipoles"

beginning[beta_a] = 10
beginning[beta_b] = 10
parameter[e_tot] = 10e6
parameter[particle] = electron

parameter[geometry] = open

b1: sbend, L = 1.0, g = 0.5, k1 = 0.2, k2 = 0.1, exact_multipoles = vertically_pure

lat: line = (b1)

use, lat
