no_digested

parameter[lattice] = "GPU quad hard fringe — multi-element for device-resident path"

beginning[beta_a] = 10
beginning[beta_b] = 10
parameter[e_tot] = 10e6
parameter[particle] = electron

parameter[geometry] = open

d1: drift, L = 0.5
q1: quadrupole, L = 0.6, k1 = 1.2, fringe_type = hard_edge_only
d2: drift, L = 0.5

lat: line = (d1, q1, d2)

use, lat
