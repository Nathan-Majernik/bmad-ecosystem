no_digested
parameter[lattice] = "GPU sextupole with aperture"
beginning[beta_a] = 10
beginning[beta_b] = 10
parameter[e_tot] = 10e6
parameter[particle] = electron
parameter[geometry] = open
! Aperture on drift (exact match) followed by sextupole (verifies tracking)
d_aper: drift, L = 0.01,
    x1_limit = 0.00015, x2_limit = 0.00015,
    y1_limit = 0.00015, y2_limit = 0.00015,
    aperture_at = exit_end
s1: sextupole, L = 0.3, k2 = 50.0
lat: line = (d_aper, s1)
use, lat
