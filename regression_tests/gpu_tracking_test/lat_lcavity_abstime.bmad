no_digested

parameter[lattice] = "GPU lcavity with absolute time tracking"

beginning[beta_a] = 10
beginning[beta_b] = 10
parameter[e_tot] = 10e6
parameter[particle] = electron

parameter[geometry] = open
parameter[absolute_time_tracking] = T

lc1: lcavity, L = 1.0, rf_frequency = 1e9, gradient = 1e5,
    n_rf_steps = 10

lat: line = (lc1)

use, lat
