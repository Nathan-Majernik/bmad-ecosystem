no_digested

parameter[lattice] = "GPU tracking drift with elliptical aperture"

beginning[beta_a] = 10
beginning[beta_b] = 10
parameter[e_tot] = 10e6
parameter[particle] = electron

parameter[geometry] = open

d1: drift, L = 1.5, aperture_type = elliptical,
    x1_limit = 2e-4, x2_limit = 2e-4,
    y1_limit = 2e-4, y2_limit = 2e-4

lat: line = (d1)

use, lat
